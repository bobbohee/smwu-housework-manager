rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // Helper functions
    // ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function affectedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function onlyChanged(fields) {
      return affectedKeys().hasOnly(fields);
    }

    function isValidInviteCode(code) {
      // 영문 대문자 + 숫자 6자, 혼동문자(0/O·1/I/L) 제외
      return code is string
        && code.matches('^[A-HJ-KM-NP-Z2-9]{6}$');
    }

    // ──────────────────────────────────────────────
    // users/{uid}
    //   - 본인만 r/w (doc id == uid이므로 별도 uid 필드 검증 불필요)
    //   - groupIds 양방향 동기화는 클라이언트가 batch write로 책임
    //   - body에는 name/email/groupIds/createdAt 저장. uid는 converter가 doc.id에서 채움
    // ──────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSelf(uid);

      allow create: if isSelf(uid)
                    && request.resource.data.email is string
                    && request.resource.data.name is string
                    && request.resource.data.groupIds is list;

      allow update: if isSelf(uid);

      allow delete: if isSelf(uid);
    }

    // ──────────────────────────────────────────────
    // groups/{groupId}
    //   - read: 멤버만
    //   - create: 본인이 owner이자 단독 멤버
    //   - update: 3가지 분기
    //       a) ownerId(방장)만 메타 변경(name, inviteCode, ownerId 위임, 강퇴)
    //       b) 본인 합류: memberUids에 본인 한 명만 추가
    //       c) 본인 탈퇴: memberUids에서 본인 한 명만 제거 (방장 제외)
    //   - delete: 방장만
    // ──────────────────────────────────────────────
    match /groups/{groupId} {
      function isOwner() {
        return isSignedIn() && request.auth.uid == resource.data.ownerId;
      }

      function isMember() {
        return isSignedIn() && request.auth.uid in resource.data.memberUids;
      }

      allow read: if isMember();

      allow create: if isSignedIn()
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.memberUids == [request.auth.uid]
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && isValidInviteCode(request.resource.data.inviteCode);

      // a) 방장: 전체 필드 변경 허용 (강퇴·위임 포함). 단 memberUids에서 본인 제외 금지(탈퇴는 b/c 경로).
      allow update: if isOwner()
                    && request.resource.data.ownerId in request.resource.data.memberUids;

      // b) 합류
      allow update: if isSignedIn()
                    && !(request.auth.uid in resource.data.memberUids)
                    && request.auth.uid in request.resource.data.memberUids
                    && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
                    && resource.data.memberUids.hasAll(
                         request.resource.data.memberUids.removeAll([request.auth.uid])
                       )
                    && onlyChanged(['memberUids', 'memberNames']);

      // c) 탈퇴 (방장 제외)
      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.memberUids
                    && !(request.auth.uid in request.resource.data.memberUids)
                    && resource.data.ownerId != request.auth.uid
                    && request.resource.data.memberUids.size() == resource.data.memberUids.size() - 1
                    && request.resource.data.memberUids.hasAll(
                         resource.data.memberUids.removeAll([request.auth.uid])
                       )
                    && onlyChanged(['memberUids', 'memberNames']);

      // d) 본인 이름 self-heal: 멤버가 자기 memberNames 키만 수정 허용
      //    합류 시 batch가 누락됐거나 displayName이 비어있던 케이스 회복용.
      //    legacy group(memberNames 필드 자체 없음)도 대응하기 위해 get(default)
      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.memberUids
                    && request.resource.data.memberUids == resource.data.memberUids
                    && onlyChanged(['memberNames'])
                    && request.resource.data.memberNames
                         .diff(resource.data.get('memberNames', {}))
                         .affectedKeys()
                         .hasOnly([request.auth.uid])
                    && request.resource.data.memberNames[request.auth.uid] is string
                    && request.resource.data.memberNames[request.auth.uid].size() > 0
                    && request.resource.data.memberNames[request.auth.uid].size() <= 30;

      allow delete: if isOwner();
    }

    // ──────────────────────────────────────────────
    // inviteCodes/{code}
    //   - 비멤버가 그룹 합류 전 코드→groupId lookup용. groups read 권한 노출 회피.
    //   - read: 인증된 누구나 (코드 자체가 비밀)
    //   - create: 본인이 ownerId일 때만. groupId-ownerId 일관성은 클라이언트 batch가 보장
    //   - update: 금지 (회전은 delete + create)
    //   - delete: 등록 당시 owner (방장 위임 시 stale 가능, Day 7 정비)
    // ──────────────────────────────────────────────
    match /inviteCodes/{code} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.groupId is string
                    && isValidInviteCode(code);

      allow update: if false;

      allow delete: if isSignedIn()
                    && resource.data.ownerId == request.auth.uid;
    }

    // ──────────────────────────────────────────────
    // Cross-collection helpers (chores·choreLog용)
    //   주의: get()은 비용 발생. 캐시되지 않음.
    // ──────────────────────────────────────────────
    function groupData(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }

    function isGroupMember(groupId) {
      return isSignedIn() && request.auth.uid in groupData(groupId).memberUids;
    }

    function isGroupOwner(groupId) {
      return isSignedIn() && request.auth.uid == groupData(groupId).ownerId;
    }

    function choreData(choreId) {
      return get(/databases/$(database)/documents/chores/$(choreId)).data;
    }

    // ──────────────────────────────────────────────
    // chores/{choreId}
    //   - read: 해당 그룹 멤버
    //   - create/update/delete: 그룹 멤버 (방장 한정 X — 멤버 누구나 편집)
    //   - 핵심 검증: groupId 변경 금지(소속 이동 차단)
    // ──────────────────────────────────────────────
    match /chores/{choreId} {
      allow read: if isGroupMember(resource.data.groupId);

      allow create: if isSignedIn()
                    && isGroupMember(request.resource.data.groupId)
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.mode in ['rotation', 'fixed']
                    && request.resource.data.color is string
                    && request.resource.data.rotationOrder is list
                    && request.resource.data.fixedSchedule is list
                    && request.resource.data.rules is list
                    && request.resource.data.currentTurnIndex is int
                    && request.resource.data.allowProxyComplete is bool;

      allow update: if isGroupMember(resource.data.groupId)
                    && request.resource.data.groupId == resource.data.groupId;

      allow delete: if isGroupMember(resource.data.groupId);
    }

    // ──────────────────────────────────────────────
    // choreLog/{logId}
    //   - read: 해당 그룹 멤버
    //   - create: 그룹 멤버 + completedByActual=본인 + active=true
    //     · rotation: completedBy는 현재 차례 멤버(또는 allowProxyComplete=true면 참여 멤버 누구나)
    //     · 본 Rules에서는 멤버십·active만 검증, 차례 검증은 클라이언트 책임(get 비용↓)
    //   - update: 방장만 + 비활성화 분기(active true→false + deactivateReason 입력)만 허용
    //   - delete: 금지 (보존)
    // ──────────────────────────────────────────────
    match /choreLog/{logId} {
      allow read: if isGroupMember(resource.data.groupId);

      allow create: if isSignedIn()
                    && isGroupMember(request.resource.data.groupId)
                    && request.resource.data.completedByActual == request.auth.uid
                    && request.resource.data.completedBy is string
                    && request.resource.data.choreId is string
                    && request.resource.data.type in ['rotation', 'random']
                    && request.resource.data.active == true;

      // 방장 비활성화: active만 true→false, deactivate 메타 필드 동시 입력
      allow update: if isGroupOwner(resource.data.groupId)
                    && resource.data.active == true
                    && request.resource.data.active == false
                    && request.resource.data.deactivateReason is string
                    && request.resource.data.deactivateReason.size() > 0
                    && request.resource.data.deactivatedBy == request.auth.uid
                    && onlyChanged(['active', 'deactivateReason', 'deactivatedBy', 'deactivatedAt']);

      allow delete: if false;
    }
  }
}
